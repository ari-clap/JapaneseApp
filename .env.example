# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# Vite only exposes variables prefixed with VITE_ to the browser.

# --- Supabase (added in the Accounts phase) ---
# Safe to expose to the browser (public anon key, protected by row-level security):
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# --- Server-only secrets (added in the AI / dictionary phases) ---
# These must stay secret. They are used ONLY by serverless functions, never the browser:
# ANTHROPIC_API_KEY=
